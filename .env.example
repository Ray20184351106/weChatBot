# 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# WeChatFerry 配置
WCF_PORT=10086
WCF_HOST=127.0.0.1

# LLM API 配置 (根据使用的模型填写)
# 选项：openai / deepseek / zhipu / local
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-3.5-turbo
LLM_BASE_URL=https://api.openai.com/v1

# 训练配置
TRAIN_BATCH_SIZE=8
TRAIN_EPOCHS=3
TRAIN_LR=2e-4

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=data/logs/bot.log
